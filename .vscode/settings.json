{
  "editor.formatOnSave": true,
  "prettier.documentSelectors": ["**/*.qmd"],
  "files.associations": {
    "*.qmd": "markdown",
    ".markdownlintignore": "plaintext",
    ".prettierignore": "plaintext",
    ".gitignore": "ignore"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdownlint.config": {
    "MD013": false
  },
  "markdownlint.ignore": [
    "_book/**",
    "node_modules/**",
    ".quarto/**",
    ".markdownlintignore"
  ]
}
