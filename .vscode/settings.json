{
  "editor.formatOnSave": true,
  "prettier.documentSelectors": ["**/*.qmd"],
  "files.associations": {
    "*.qmd": "markdown",
    ".markdownlintignore": "plaintext",
    ".prettierignore": "plaintext",
    ".gitignore": "ignore"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdownlint.config": {
    "MD013": false
  },
  "markdownlint.ignore": ["docs/**", "node_modules/**", ".markdownlintignore"]
}
